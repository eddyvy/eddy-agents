OPENAI_API_KEY=your-api-key

# ── Bookings Notifications Workflow ────────────────────────────────────────────
# URL of the reservations API that returns the bookings array
BOOKINGS_API_URL=https://your-pms-api.example.com/bookings

# Twilio credentials (https://console.twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
# Sender number in whatsapp:<E.164> format (Twilio sandbox or approved number)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Content SIDs for each WhatsApp template (HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx)
TWILIO_TEMPLATE_WELCOME_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TEMPLATE_EVENTS_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TEMPLATE_ROOMSERVICE_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TEMPLATE_CHECKOUT_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx 
